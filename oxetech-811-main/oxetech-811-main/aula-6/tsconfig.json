{
	"compilerOptions": {
		"target": "ES2022",
		"module": "Node16",
		"moduleResolution": "Node16",
		"strict": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"outDir": "dist",
		"rootDir": ".",
		"isolatedModules": true,
		"types": ["node", "vitest"]
	},
	"include": [
		"src/**/*.ts",
		"scripts/**/*.ts",
		"tests/**/*.ts",
		"vitest.config.mts"
	],
	"exclude": ["node_modules", "dist"]
}
